# =============================================
# Kafka + Spark Streaming Pipeline — ENV CONFIG
# =============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ----- Kafka -----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=clickstream_events
KAFKA_CONSUMER_GROUP=spark_streaming_group
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_NUM_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# ----- Google Cloud Platform -----
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=clickstream_data
BIGQUERY_TABLE=events
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ----- Spark -----
SPARK_MASTER=local[*]
SPARK_APP_NAME=ClickstreamStreamingJob
SPARK_BATCH_INTERVAL_SECONDS=10
SPARK_CHECKPOINT_DIR=/tmp/spark-checkpoints

# ----- Monitoring -----
PROMETHEUS_PORT=8000
GRAFANA_PORT=3000
